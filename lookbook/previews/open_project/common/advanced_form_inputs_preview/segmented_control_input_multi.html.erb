<%
  the_form = Class.new(ApplicationForm) do
    form do |f|
      f.segmented_control(
        name: :priority,
        label: "Priority",
        value: "normal",
        items: [
          { value: "low",    label: "Low" },
          { value: "normal", label: "Normal" },
          { value: "high",   label: "High" }
        ]
      )

      f.submit(name: "submit", label: "Save")
    end
  end
%>

<%= primer_form_with(url: "/abc", method: :post) do |f|
  render(the_form.new(f))
end %>
